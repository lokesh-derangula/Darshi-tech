datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  phone       String
  password    String       // Bcrypt hashed
  college     String
  branch      String
  year        String
  role        String       @default("STUDENT") // STUDENT, ADMIN
  isVerified  Boolean      @default(false)
  otpCode     String?      // For verification & reset
  otpExpiry   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  attendance  Attendance[]
}

model Course {
  id          String       @id @default(uuid())
  title       String
  description String
  duration    String       // e.g. "6 Weeks"
  price       Float
  category    String       // Research, Full Stack, Product Development, Web Development, Workshops, Training
  thumbnail   String       // Image URL or Base64
  status      String       @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  classes     Class[]
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  paymentId  String   @unique
  status     String   @default("ACTIVE") // PENDING, ACTIVE, COMPLETED
  enrolledAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Class {
  id          String       @id @default(uuid())
  courseId    String
  meetingLink String
  date        String       // YYYY-MM-DD
  time        String       // HH:MM
  title       String
  createdAt   DateTime     @default(now())
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendance  Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  classId   String
  present   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
}
